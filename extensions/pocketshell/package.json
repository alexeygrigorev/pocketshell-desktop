				},
				{
					"command": "pocketshell.tmux-ui.detectPortsTreePane",
					"when": "view == pocketshell.tmuxSessions && (viewItem == tmuxUiWindow || viewItem == tmuxUiPane)",
					"group": "1_pane"
				},
				{
					"command": "pocketshell.tmux-ui.sendTextToPane",
