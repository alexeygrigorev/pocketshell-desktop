				},
				{
					"command": "pocketshell.snippets.openComposer",
					"when": "view == pocketshell.tmuxSessions && (viewItem == tmuxUiWindow || viewItem == tmuxUiPane)",
					"group": "1_pane"
				},
				{
					"command": "pocketshell.tmux-ui.sendKeysToPane",
					"when": "view == pocketshell.tmuxSessions && (viewItem == tmuxUiWindow || viewItem == tmuxUiPane)",
					"group": "1_pane"
				},
				{
					"command": "pocketshell.tmux-ui.resizeTreePane",
					"when": "view == pocketshell.tmuxSessions && (viewItem == tmuxUiWindow || viewItem == tmuxUiPane)",
					"group": "1_pane"
				},
				{
					"command": "pocketshell.tmux-ui.renameTreeItem",
					"when": "view == pocketshell.tmuxSessions && (viewItem == tmuxUiSession || viewItem == tmuxUiWindow)",
