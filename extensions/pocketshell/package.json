{
	"name": "pocketshell",
	"displayName": "PocketShell",
	"description": "Terminal-first, agent-aware SSH client",
	"publisher": "pocketshell",
	"version": "0.1.1",
	"license": "MIT",
	"engines": {
		"vscode": "^1.70.0"
	},
	"main": "./out/extension",
	"categories": [
		"Other"
	],
	"extensionKind": [
		"ui",
		"workspace"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"contributes": {
		"terminal": {
			"profiles": [
				{
					"id": "pocketshell.ssh",
					"title": "PocketShell SSH"
				}
			]
		},
		"commands": [
			{
				"command": "pocketshell.connect",
				"title": "PocketShell: Open Terminal"
			},
			{
				"command": "pocketshell.hostDetail.open",
				"title": "PocketShell: Open Host Detail",
				"icon": "$(server-environment)"
			},
			{
				"command": "pocketshell.watchedFolders.manage",
				"title": "Watched Folders: Manage",
				"category": "PocketShell",
				"icon": "$(folder-active)"
			},
			{
				"command": "pocketshell.watchedFolders.add",
				"title": "Watched Folders: Add",
				"category": "PocketShell",
				"icon": "$(add)"
			},
			{
				"command": "pocketshell.watchedFolders.edit",
				"title": "Watched Folders: Edit",
				"category": "PocketShell",
				"icon": "$(edit)"
			},
			{
				"command": "pocketshell.watchedFolders.delete",
				"title": "Watched Folders: Delete",
				"category": "PocketShell",
				"icon": "$(trash)"
			},
			{
				"command": "pocketshell.watchedFolders.moveUp",
				"title": "Watched Folders: Move Up",
				"category": "PocketShell",
				"icon": "$(arrow-up)"
			},
			{
				"command": "pocketshell.watchedFolders.moveDown",
				"title": "Watched Folders: Move Down",
				"category": "PocketShell",
				"icon": "$(arrow-down)"
			},
			{
				"command": "pocketshell.watchedFolders.discover",
				"title": "Watched Folders: Discover Project Roots",
				"category": "PocketShell",
				"icon": "$(search)"
			},
			{
				"command": "pocketshell.watchedFolders.openSession",
				"title": "Watched Folders: Open Session",
				"category": "PocketShell",
				"icon": "$(terminal)"
			},
			{
				"command": "pocketshell.sessions.create",
				"title": "Sessions: Create Shell or Agent Session",
				"category": "PocketShell",
				"icon": "$(terminal-tmux)"
			},
			{
				"command": "pocketshell.session.create",
				"title": "Session: Create Shell or Agent Session",
				"category": "PocketShell",
				"icon": "$(terminal-tmux)"
			},
			{
				"command": "pocketshell.addHost",
				"title": "PocketShell: Add Host"
			},
			{
				"command": "pocketshell.importSshConfig",
				"title": "PocketShell: Import SSH Config"
			},
			{
				"command": "pocketshell.keys.manage",
				"title": "PocketShell: Manage SSH Keys",
				"category": "PocketShell",
				"icon": "$(key)"
			},
			{
				"command": "pocketshell.keys.list",
				"title": "SSH Keys: List Managed Keys",
				"category": "PocketShell",
				"icon": "$(list-tree)"
			},
			{
				"command": "pocketshell.keys.import",
				"title": "SSH Keys: Import Private Key",
				"category": "PocketShell",
				"icon": "$(cloud-upload)"
			},
			{
				"command": "pocketshell.keys.generate",
				"title": "SSH Keys: Generate ed25519 Key",
				"category": "PocketShell",
				"icon": "$(add)"
			},
			{
				"command": "pocketshell.keys.assignToHost",
				"title": "SSH Keys: Assign Key to Host",
				"category": "PocketShell",
				"icon": "$(link)"
			},
			{
				"command": "pocketshell.disconnect",
				"title": "PocketShell: Disconnect"
			},
			{
				"command": "pocketshell.editHost",
				"title": "PocketShell: Edit Host"
			},
			{
				"command": "pocketshell.deleteHost",
				"title": "PocketShell: Delete Host"
			},
			{
				"command": "pocketshell.openRemoteFile",
				"title": "PocketShell: Open Remote File"
			},
			{
				"command": "pocketshell.settings.open",
				"title": "PocketShell: Open Settings",
				"category": "PocketShell",
				"icon": "$(settings-gear)"
			},
			{
				"command": "pocketshell.diagnostics.showReport",
				"title": "Diagnostics: Show Report",
				"category": "PocketShell",
				"icon": "$(output)"
			},
			{
				"command": "pocketshell.diagnostics.copyReport",
				"title": "Diagnostics: Copy Report",
				"category": "PocketShell",
				"icon": "$(copy)"
			},
			{
				"command": "pocketshell.git.status",
				"title": "Git: Status",
				"category": "PocketShell",
				"icon": "$(git-branch)"
			},
			{
				"command": "pocketshell.git.branches",
				"title": "Git: Branches",
				"category": "PocketShell"
			},
			{
				"command": "pocketshell.git.history",
				"title": "Git: History",
				"category": "PocketShell",
				"icon": "$(history)"
			},
			{
				"command": "pocketshell.git.pull",
				"title": "Git: Pull",
				"category": "PocketShell",
				"icon": "$(repo-pull)"
			},
			{
				"command": "pocketshell.jobs.list",
				"title": "Jobs: List",
				"category": "PocketShell"
			},
			{
				"command": "pocketshell.jobs.logs",
				"title": "Jobs: Logs",
				"category": "PocketShell"
			},
			{
				"command": "pocketshell.jobs.cancel",
				"title": "Jobs: Cancel",
				"category": "PocketShell"
			},
			{
				"command": "pocketshell.bootstrap.status",
				"title": "Bootstrap: Status",
				"category": "PocketShell"
			},
			{
				"command": "pocketshell.bootstrap.install",
				"title": "Bootstrap: Install",
				"category": "PocketShell"
			},
			{
				"command": "pocketshell.bootstrap.upgrade",
				"title": "Bootstrap: Upgrade",
				"category": "PocketShell"
			},
			{
				"command": "pocketshell.env.list",
				"title": "Env: List",
				"category": "PocketShell"
			},
			{
				"command": "pocketshell.env.set",
				"title": "Env: Set",
				"category": "PocketShell"
			},
			{
				"command": "pocketshell.env.unset",
				"title": "Env: Unset",
				"category": "PocketShell"
			},
			{
				"command": "pocketshell.logs.show",
				"title": "Logs: Show",
				"category": "PocketShell"
			},
			{
				"command": "pocketshell.logs.tail",
				"title": "Logs: Tail",
				"category": "PocketShell"
			},
			{
				"command": "pocketshell.logs.clear",
				"title": "Logs: Clear",
				"category": "PocketShell"
			},
			{
				"command": "pocketshell.usage.show",
				"title": "Usage: Show",
				"category": "PocketShell"
			},
			{
				"command": "pocketshell.usage.panel",
				"title": "Usage: Show Panel",
				"category": "PocketShell",
				"icon": "$(graph)"
			},
			{
				"command": "pocketshell.usage.refresh",
				"title": "Usage: Refresh",
				"category": "PocketShell",
				"icon": "$(refresh)"
			},
			{
				"command": "pocketshell.usage.provider",
				"title": "Usage: By Provider",
				"category": "PocketShell"
			},
			{
				"command": "pocketshell.agent.detect",
				"title": "Agent: Detect on Host",
				"category": "PocketShell",
				"icon": "$(robot)"
			},
			{
				"command": "pocketshell.agent.showDetected",
				"title": "Agent: Show Detected",
				"category": "PocketShell"
			},
			{
				"command": "pocketshell.editor.open",
				"title": "Editor: Open Remote Document",
				"category": "PocketShell",
				"icon": "$(go-to-file)"
			},
			{
				"command": "pocketshell.editor.save",
				"title": "Editor: Save",
				"category": "PocketShell",
				"icon": "$(save)"
			},
			{
				"command": "pocketshell.editor.revert",
				"title": "Editor: Revert",
				"category": "PocketShell",
				"icon": "$(discard)"
			},
			{
				"command": "pocketshell.terminal.new",
				"title": "Terminal: New Session",
				"category": "PocketShell",
				"icon": "$(terminal)"
			},
			{
				"command": "pocketshell.terminal.list",
				"title": "Terminal: List Sessions",
				"category": "PocketShell",
				"icon": "$(list-tree)"
			},
			{
				"command": "pocketshell.terminal.close",
				"title": "Terminal: Close Session",
				"category": "PocketShell",
				"icon": "$(trash)"
			},
			{
				"command": "pocketshell.hooks.status",
				"title": "Hooks: Status",
				"category": "PocketShell",
				"icon": "$(extensions)"
			},
			{
				"command": "pocketshell.hooks.list",
				"title": "Hooks: List",
				"category": "PocketShell"
			},
			{
				"command": "pocketshell.hooks.add",
				"title": "Hooks: Add",
				"category": "PocketShell",
				"icon": "$(add)"
			},
			{
				"command": "pocketshell.hooks.remove",
				"title": "Hooks: Remove",
				"category": "PocketShell",
				"icon": "$(trash)"
			},
			{
				"command": "pocketshell.reply.send",
				"title": "Reply: Send",
				"category": "PocketShell",
				"icon": "$(send)"
			},
			{
				"command": "pocketshell.reply.queue",
				"title": "Reply: Queue",
				"category": "PocketShell",
				"icon": "$(checklist)"
			},
			{
				"command": "pocketshell.reply.status",
				"title": "Reply: Queue Status",
				"category": "PocketShell",
				"icon": "$(info)"
			},
			{
				"command": "pocketshell.files.browse",
				"title": "Files: Browse",
				"category": "PocketShell",
				"icon": "$(folder)"
			},
			{
				"command": "pocketshell.files.watch",
				"title": "Files: Watch Directory",
				"category": "PocketShell",
				"icon": "$(eye)"
			},
			{
				"command": "pocketshell.files.stopWatch",
				"title": "Files: Stop Watching",
				"category": "PocketShell",
				"icon": "$(eye-closed)"
			},
			{
				"command": "pocketshell.pocketshell.detect",
				"title": "PocketShell: Detect on Host",
				"category": "PocketShell",
				"icon": "$(search)"
			},
			{
				"command": "pocketshell.pocketshell.status",
				"title": "PocketShell: Show Status",
				"category": "PocketShell",
				"icon": "$(info)"
			},
			{
				"command": "pocketshell.pocketshell.install",
				"title": "PocketShell: Install/Upgrade",
				"category": "PocketShell",
				"icon": "$(cloud-download)"
			},
			{
				"command": "pocketshell.palette.open",
				"title": "Open Slash Command Palette",
				"category": "PocketShell",
				"icon": "$(symbol-text)"
			},
			{
				"command": "pocketshell.palette.listCommands",
				"title": "List Registered Commands",
				"category": "PocketShell"
			},
			{
				"command": "pocketshell.palette.registerCommand",
				"title": "Register Command",
				"category": "PocketShell",
				"icon": "$(add)"
			},
			{
				"command": "pocketshell.tmux.list",
				"title": "Tmux: List Sessions",
				"category": "PocketShell",
				"icon": "$(list-tree)"
			},
			{
				"command": "pocketshell.tmux.new",
				"title": "Tmux: New Session",
				"category": "PocketShell",
				"icon": "$(add)"
			},
			{
				"command": "pocketshell.tmux.attach",
				"title": "Tmux: Attach Session",
				"category": "PocketShell",
				"icon": "$(terminal-tmux)"
			},
			{
				"command": "pocketshell.tmux.rename",
				"title": "Tmux: Rename Session",
				"category": "PocketShell",
				"icon": "$(edit)"
			},
			{
				"command": "pocketshell.tmux.kill",
				"title": "Tmux: Kill Session",
				"category": "PocketShell",
				"icon": "$(trash)"
			},
			{
				"command": "pocketshell.tmux.newWindow",
				"title": "Tmux: New Window",
				"category": "PocketShell",
				"icon": "$(window)"
			},
			{
				"command": "pocketshell.tmux.send",
				"title": "Tmux: Send Keys",
				"category": "PocketShell"
			},
			{
				"command": "pocketshell.tmux.detach",
				"title": "Tmux: Detach",
				"category": "PocketShell",
				"icon": "$(debug-disconnect)"
			},
			{
				"command": "pocketshell.tmux-ui.showTree",
				"title": "Tmux UI: Show Session Tree",
				"category": "PocketShell",
				"icon": "$(list-tree)"
			},
			{
				"command": "pocketshell.tmux-ui.newSession",
				"title": "Tmux UI: New Session",
				"category": "PocketShell",
				"icon": "$(add)"
			},
			{
				"command": "pocketshell.tmux-ui.openSession",
				"title": "Tmux UI: Open Session Terminal",
				"category": "PocketShell",
				"icon": "$(terminal-tmux)"
			},
			{
				"command": "pocketshell.tmux-ui.splitPane",
				"title": "Tmux UI: Split Pane",
				"category": "PocketShell"
			},
			{
				"command": "pocketshell.tmux-ui.capturePane",
				"title": "Tmux UI: Capture Pane",
				"category": "PocketShell",
				"icon": "$(eye)"
			}
		],
		"menus": {
			"view/item/context": [
				{
					"command": "pocketshell.hostDetail.open",
					"when": "view == pocketshell.hosts",
					"group": "inline"
				},
				{
					"command": "pocketshell.disconnect",
					"when": "view == pocketshell.hosts && viewItem == connectedHost",
					"group": "inline"
				},
				{
					"command": "pocketshell.connect",
					"when": "view == pocketshell.hosts",
					"group": "0_terminal"
				},
				{
					"command": "pocketshell.editHost",
					"when": "view == pocketshell.hosts",
					"group": "1_manage"
				},
				{
					"command": "pocketshell.deleteHost",
					"when": "view == pocketshell.hosts",
					"group": "1_manage"
				},
				{
					"command": "pocketshell.usage.show",
					"when": "view == pocketshell.hosts",
					"group": "2_usage"
				},
				{
					"command": "pocketshell.usage.refresh",
					"when": "view == pocketshell.hosts",
					"group": "2_usage"
				}
			],
			"terminal/context": [
				{
					"command": "pocketshell.usage.panel",
					"group": "pocketshell_usage"
				},
				{
					"command": "pocketshell.usage.refresh",
					"group": "pocketshell_usage"
				}
			]
		},
		"viewsContainers": {
			"activitybar": [
				{
					"id": "pocketshell",
					"title": "PocketShell",
					"icon": "$(remote)"
				}
			]
		},
		"views": {
			"pocketshell": [
				{
					"id": "pocketshell.hosts",
					"name": "SSH Hosts",
					"icon": "$(server)"
				}
			]
		}
	},
	"devDependencies": {
		"@types/node": "^24.13.2"
	},
	"scripts": {
		"compile": "gulp compile-extension:pocketshell",
		"watch": "gulp watch-extension:pocketshell"
	},
	"dependencies": {
		"sql.js": "^1.14.1",
		"ssh2": "^1.17.0"
	}
}
