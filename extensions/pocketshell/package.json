					"group": "pocketshell_ports"
				},
				{
					"command": "pocketshell.snippets.insertTerminal",
					"group": "pocketshell_snippets"
				},
				{
					"command": "pocketshell.snippets.openComposer",
					"group": "pocketshell_snippets"
				},
				{
					"command": "pocketshell.usage.panel",
					"group": "pocketshell_usage"
				},
				{
					"command": "pocketshell.usage.refresh",
					"group": "pocketshell_usage"
