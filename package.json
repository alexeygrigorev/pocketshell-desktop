{
  "name": "pocketshell-desktop",
  "version": "1.0.0",
  "description": "A terminal-first, agent-aware desktop SSH client for the developer workstation you already use — a desktop companion to [PocketShell Android](https://github.com/alexeygrigorev/pocketshell).",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "scripts": {
    "lint": "echo \"lint not configured yet\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "bash scripts/build.sh",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "build:e2e": "tsc -p test/e2e-inhost/tsconfig.json",
    "test:e2e:inhost": "bash scripts/test-e2e-inhost.sh",
    "test:docker:up": "docker compose -f test/fixtures/docker/docker-compose.yml up -d --build",
    "test:docker:down": "docker compose -f test/fixtures/docker/docker-compose.yml down -v",
    "package": "bash scripts/package.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexeygrigorev/pocketshell-desktop.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/alexeygrigorev/pocketshell-desktop/issues"
  },
  "homepage": "https://github.com/alexeygrigorev/pocketshell-desktop#readme",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mocha": "^10.0.10",
    "@types/ssh2": "^1.15.5",
    "@types/yauzl": "^2.10.3",
    "@types/vscode": "1.125.0",
    "@types/yazl": "^2.4.2",
    "@vscode/test-electron": "3.0.0",
    "glob": "^10.5.0",
    "mocha": "^10.8.2",
    "ssh2": "^1.17.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "yazl": "^2.4.3"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "sql.js": "^1.14.1",
    "sshpk": "^1.18.0",
    "yauzl": "^3.3.1"
  }
}
